    {
      "slice_type": "employee_approach",
      "primary": {
        "title": "Moje podejście do terapii",
        "quote": "Praca z pacjentem neurologicznym to nie tylko ćwiczenia. To odbudowywanie nadziei, wiary w siebie i powrót do życia, które kiedyś było normalne.",
        "image": {
          "url": "https://res.cloudinary.com/djyf1kk36/image/upload/exuraortho/i5lzfocdqujtdbvcniho.png",
          "alt": "Marek Wiśniewski podczas terapii"
        },
        "image_position": "right"
      },
      "items": [
        {
          "principle_title": "Cierpliwość i konsekwencja",
          "principle_description": "Rehabilitacja neurologiczna to maraton, nie sprint. Małe codzienne postępy prowadzą do wielkich zmian. Nie śpieszymy się — idziemy pewnie do celu."
        },
        {
          "principle_title": "Współpraca z rodziną",
          "principle_description": "Angażuję rodzinę pacjenta w proces rehabilitacji. Bliscy są ważnym elementem terapii — uczę ich, jak wspierać i motywować."
        },
        {
          "principle_title": "Podejście holistyczne",
          "principle_description": "Patrzę na pacjenta całościowo — nie tylko na niedowład czy zaburzenia ruchu, ale na jego samopoczucie, motywację i jakość życia."
        }
      ]
